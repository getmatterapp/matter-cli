{
  "name": "matter-cli",
  "version": "0.1.0",
  "description": "CLI and TUI for the Matter reading app",
  "type": "module",
  "main": "src/cli.tsx",
  "bin": {
    "matter": "src/cli.tsx"
  },
  "scripts": {
    "dev": "bun run src/cli.tsx",
    "build": "bun run scripts/build.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@opentui/core": "^0.1.95",
    "@opentui/react": "^0.1.95",
    "commander": "^13.1.0",
    "open": "^10.1.0",
    "react": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.1.0",
    "typescript": "^5.8.3"
  }
}
